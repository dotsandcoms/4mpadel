# Supabase - connects on any domain (localhost, 4mpadel.vercel.app, production)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Paystack — live key used in production builds
VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_live_public_key

# Paystack — test key used automatically on localhost / vite dev
VITE_PAYSTACK_PUBLIC_KEY_TEST=pk_test_your_test_public_key

# Supabase Edge Function secrets (Dashboard → Project Settings → Edge Functions):
# PAYSTACK_SECRET_KEY=sk_live_...        — verifies live / production payments
# PAYSTACK_SECRET_KEY_TEST=sk_test_...   — verifies localhost / pk_test payments
#
# Edge functions pick the correct secret from each payment's is_test flag.
#
# Payment reminders (manual events only):
# PAYMENT_REMINDERS_ENABLED=true   — must be set explicitly to send reminders
# Leave unset or false to keep reminders disabled (safe default)

RANKEDIN_EMAIL=
RANKEDIN_PASSWORD=
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# Google Maps / Places (Event Builder address autocomplete)
# Must also be set in Vercel/hosting env — Vite bakes this in at build time, not runtime.
# In Google Cloud Console: enable Maps JavaScript API + Places API, restrict key to your domains.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
