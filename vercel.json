{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/calendar/:slug",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(WhatsApp|facebookexternalhit|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot).*" }
      ],
      "destination": "/api/seo-preview?type=event&slug=:slug"
    },
    {
      "source": "/gallery/:slug",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(WhatsApp|facebookexternalhit|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot).*" }
      ],
      "destination": "/api/seo-preview?type=album&slug=:slug"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
